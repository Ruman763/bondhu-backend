POSTGRES_DB=bondhu_app
POSTGRES_USER=bondhu_admin
POSTGRES_PASSWORD=change_this_super_strong_password

NOCODB_JWT_SECRET=change_this_to_a_long_random_secret

API_PORT=3000
NODE_ENV=production
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
GOOGLE_CLIENT_ID=
# Comma-separated origins for REST + Socket.IO (Flutter web / app). Use your production domain in deploy.
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
APP_BASE_URL=http://localhost:3000
# Flutter: --dart-define=API_BASE_URL=https://your-api.example.com (same host as Socket.IO unless CHAT_SERVER_URL is set)
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Protects /admin panel API access. Required for admin panel usage.
ADMIN_PANEL_KEY=change_this_admin_key_min_24_chars
